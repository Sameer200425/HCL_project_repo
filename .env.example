# =============================================================
# Environment Variables for Bank Fraud Detection
# =============================================================
# Copy this file to .env and configure for your environment
# cp .env.example .env

# --- Security ---
# App environment mode: development | production
ENVIRONMENT=development

# IMPORTANT: Set a stable secret key for production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret-key

# Authentication switch (development only).
# In production, DISABLE_AUTH must remain false.
DISABLE_AUTH=false

# Optional public-user profile used when DISABLE_AUTH=true
PUBLIC_USER_EMAIL=public@example.local
PUBLIC_USER_USERNAME=public_user
PUBLIC_USER_FULL_NAME=Public Analyst

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
# SQLite (default for development)
DATABASE_URL=sqlite:///./data/fraud_detection.db

# PostgreSQL (production) - required when ENVIRONMENT=production
# DATABASE_URL=postgresql://user:password@localhost:5432/fraud_detection

# --- Model ---
MODEL_TYPE=cnn
CHECKPOINT_DIR=checkpoints

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8001

# --- Frontend ---
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_AUTH_DISABLED=false
NEXT_PUBLIC_API_TIMEOUT_MS=12000
NEXT_PUBLIC_API_RETRY_COUNT=1

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Trusted hosts / cookies ---
TRUSTED_HOSTS=localhost,127.0.0.1
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false

# --- Auth abuse protection ---
LOGIN_MAX_FAILS=5
LOGIN_LOCK_WINDOW_MINUTES=15
LOGIN_LOCK_MINUTES=15
